# Database Configuration
DB_NAME='database_name'
DB_USER='database_user'
DB_PASSWORD='database_password'

# Optionally, you can use a data source name (DSN)
# When using a DSN, you can remove the DB_NAME, DB_USER, DB_PASSWORD, and DB_HOST variables
# DATABASE_URL='mysql://database_user:database_password@database_host:database_port/database_name'

# Optional database variables
# DB_HOST='localhost'
# DB_PREFIX='wp_'

# Environment
WP_ENV='development'
WP_HOME='http://ckl.test'
WP_SITEURL="${WP_HOME}/wp"

# Specify optional debug.log path
# WP_DEBUG_LOG='/path/to/debug.log'

# Generate your keys here: https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'

# =================================================================
# Email Configuration - Brevo (Sendinblue) SMTP
# =================================================================
# Post SMTP Plugin Configuration for reliable email delivery
# Get your Brevo API Key from: https://app.brevo.com/settings/keys

# Email Sender Information
POST_SMTP_FROM_EMAIL='noreply@yourdomain.com'
POST_SMTP_FROM_NAME='CKL Car Rental'

# Brevo SMTP Configuration
# Mailer type: 'smtp' for Brevo
POST_SMTP_MAILER='smtp'

# SMTP Settings for Brevo
POST_SMTP_HOST='smtp-relay.brevo.com'
POST_SMTP_PORT='587'  # Use 587 for TLS, 465 for SSL
POST_SMTP_AUTH='on'   # Enable authentication

# Your Brevo API Key (used as SMTP username)
# Get your API key from: https://app.brevo.com/settings/keys
# SMTP password should be left empty (API key is used as username)
POST_SMTP_USER='your_brevo_api_key_v3_here'
POST_SMTP_PASS=''

# Encryption: 'tls' or 'ssl'
POST_SMTP_ENCRYPTION='tls'

# =================================================================
# Email Logging & Debugging (Development Only)
# =================================================================
# Set to 'true' to enable email logging in development
# Set to 'false' in production
POST_SMTP_DEBUG=false

# Set to 'true' to prevent emails from being sent (development testing)
# Set to 'false' in production to send real emails
POST_SMTP_DO_NOT_SEND=false

# =================================================================
# Brevo Account Setup Checklist
# =================================================================
# Before using Brevo SMTP, complete these steps:
#
# 1. Create Brevo Account: https://www.brevo.com
# 2. Verify Sender Domain:
#    - Add your domain in Brevo Dashboard > Senders > SMTP
#    - Configure DNS records (SPF, DKIM) with your domain registrar
#    - Required DNS records:
#      SPF:  v=spf1 include:spf.brevo.com ~all
#      DKIM: (provided in Brevo sender settings)
# 3. Get API Key:
#    - Go to Settings > API Keys > Create new key
#    - Select SMTP permissions
#    - Copy the key v3 (starts with xkeysib-...)
# 4. Configure Plugin:
#    - Install and activate Post SMTP
#    - Go to WP Admin > Post SMTP > Setup Wizard
#    - Select "SMTP" as mailer
#    - Enter the settings from above
# 5. Test Email:
#    - Use the "Send Test Email" in Post SMTP settings
#    - Verify delivery and check spam folder
#
# =================================================================
# Production Notes
# =================================================================
# In production:
# - Set WP_ENV='production'
# - Set POST_SMTP_DEBUG=false
# - Set POST_SMTP_DO_NOT_SEND=false
# - Use a verified sender domain
# - Ensure DNS records (SPF/DKIM) are configured
# - Test email delivery before going live
