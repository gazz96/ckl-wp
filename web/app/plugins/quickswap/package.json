{
  "name": "quickswap-block-manager",
  "version": "1.0.0",
  "description": "Gutenberg Block Manager for QuickSwap - Quick Insert Panel with Block Collections",
  "author": "CK Langkawi",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "build": "npm run build:block-manager && npm run build:admin",
    "build:block-manager": "wp-scripts build block-manager/src/index.js --output-path=block-manager/build",
    "build:admin": "wp-scripts build block-manager/src/admin/index.js --output-path=block-manager/build-admin",
    "start": "npm run start:block-manager",
    "start:block-manager": "wp-scripts start block-manager/src/index.js --output-path=block-manager/build",
    "start:admin": "wp-scripts start block-manager/src/admin/index.js --output-path=block-manager/build-admin"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^6.0.0",
    "@wordpress/block-editor": "^12.0.0",
    "@wordpress/blocks": "^12.0.0",
    "@wordpress/compose": "^6.0.0",
    "@wordpress/components": "^25.0.0",
    "@wordpress/data": "^9.0.0",
    "@wordpress/edit-post": "^7.0.0",
    "@wordpress/element": "^5.0.0",
    "@wordpress/hooks": "^3.0.0",
    "@wordpress/i18n": "^4.0.0",
    "@wordpress/icons": "^9.0.0",
    "@wordpress/keycodes": "^3.0.0",
    "@wordpress/plugins": "^6.0.0",
    "@wordpress/keyboard-shortcuts": "^4.0.0"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.0.0"
  }
}
