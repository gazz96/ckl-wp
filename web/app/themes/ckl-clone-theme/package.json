{
  "name": "ckl-clone-theme",
  "version": "1.0.0",
  "description": "A custom theme for cloning cklangkawi.com.",
  "scripts": {
    "build": "npx postcss assets/css/input.css -o assets/dist/output.css",
    "watch": "npx postcss assets/css/input.css -o assets/dist/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  },
  "dependencies": {
    "postcss-cli": "^11.0.0"
  }
}
